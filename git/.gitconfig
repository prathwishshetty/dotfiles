[init]
	defaultBranch = main

[pull]
	ff = only

[fetch]
	prune = true

[color]
	ui = auto

[core]
	pager = delta

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true
	side-by-side = false
	line-numbers = true
	syntax-theme = Monokai Extended

[merge]
	conflictstyle = diff3

[include]
	path = ~/.gitconfig.local

[alias]
	st = status -sb
	co = checkout
	br = branch
	ci = commit
	aa = add --all
	last = log -1 HEAD --stat
	lg = log --graph --decorate --oneline --all
	tree = log --graph --decorate --oneline --all
