# Let Ghostty focus on rendering; tmux handles panes and windows.
font-family = Menlo
font-size = 15
background-opacity = 0.96
window-padding-x = 10
window-padding-y = 10
cursor-style = block
copy-on-select = true
macos-option-as-alt = true
window-save-state = always
confirm-close-surface = false
term = xterm-256color
