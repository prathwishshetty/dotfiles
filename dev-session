#!/bin/zsh

set -eu
set -o pipefail

session_name="${1:-main}"
cwd="${2:-$PWD}"

if ! command -v tmux >/dev/null 2>&1; then
  print -u2 "tmux is required for dev-session"
  exit 1
fi

if ! tmux has-session -t "$session_name" 2>/dev/null; then
  tmux new-session -d -s "$session_name" -n shell -c "$cwd"
  tmux split-window -h -t "${session_name}:shell" -c "$cwd"
  tmux split-window -v -t "${session_name}:shell.2" -c "$cwd"
  tmux select-pane -t "${session_name}:shell.1"
  tmux new-window -t "$session_name" -n editor -c "$cwd"
  tmux send-keys -t "${session_name}:editor" "${EDITOR:-vim} ." C-m
  tmux new-window -t "$session_name" -n git -c "$cwd"
  tmux send-keys -t "${session_name}:git" 'git status -sb 2>/dev/null || ls' C-m
  tmux select-window -t "${session_name}:shell"
fi

exec tmux attach -t "$session_name"
